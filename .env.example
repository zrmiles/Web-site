# Скопируйте этот файл в .env и заполните значения:
# cp .env.example .env

# ОБЯЗАТЕЛЬНО: секрет для подписи JWT-токенов (минимум 32 символа, случайная строка)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=замените_на_случайную_строку_минимум_32_символа

# ОБЯЗАТЕЛЬНО: пароль администратора (задаётся один раз при первом запуске)
ADMIN_PASSWORD=замените_на_надёжный_пароль

# Порт сервера (необязательно, по умолчанию 3001)
PORT=3001

# Разрешённые источники для CORS (через запятую, необязательно)
# В dev по умолчанию: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
